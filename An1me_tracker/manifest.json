{
  "manifest_version": 3,
  "name": "An1me.to Tracker",
  "version": "6.8.0",
  "description": "Track your anime watching progress on an1me.to with cloud sync across all browsers",
  "author": "ThomasThanos",
  "permissions": [
    "storage",
    "scripting",
    "identity",
    "alarms",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://an1me.to/*",
    "https://*.an1me.to/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://graphql.anilist.co/*",
    "https://www.animefillerlist.com/*",
    "https://api.jikan.moe/*",
    "https://api.aniskip.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://an1me.to/*", "https://*.an1me.to/*"],
      "exclude_matches": [
        "https://an1me.to/watch/*",
        "https://*.an1me.to/watch/*"
      ],
      "js": ["src/content/page/watchlist-sync.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://an1me.to/*", "https://*.an1me.to/*"],
      "js": ["src/content/page/copy-guard.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://an1me.to/watch/*", "https://*.an1me.to/watch/*"],
      "js": [
        "src/common/data/multipart-mappings.js",
        "src/content/lib/config.js",
        "src/common/logger.js",
        "src/content/lib/storage.js",
        "src/content/page/anime-parser.js",
        "src/content/lib/notifications.js",
        "src/content/player/episode-writer.js",
        "src/content/player/progress-tracker.js",
        "src/content/page/watchlist-sync.js",
        "src/content/player/video-monitor.js",
        "src/content/player/skiptime-utils.js",
        "src/content/player/skiptime-styles.js",
        "src/content/player/skiptime-helper.js",
        "src/content/main.js",
        "src/common/data/merge-utils.js",
        "src/common/cloud/firebase-config.js",
        "src/common/cloud/firestore-codec.js",
        "src/common/cloud/auth-classifier.js",
        "src/common/cloud/auth-tokens.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://an1me.to/", "https://*.an1me.to/"],
      "js": ["src/content/page/continue-watching.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/icons/icon128.png",
        "src/fonts/PROXON.ttf",
        "src/fonts/comic_sans.ttf"
      ],
      "matches": ["https://an1me.to/*", "https://*.an1me.to/*"]
    }
  ]
}
